# --- General ---
GRACEKELLY_ENV=development
GRACEKELLY_HOST=127.0.0.1
GRACEKELLY_PORT=8011
GRACEKELLY_LOG_LEVEL=INFO
GRACEKELLY_API_KEY=

# --- Browser (primary execution path) ---
GRACEKELLY_BROWSER_ENABLED=false
GRACEKELLY_BROWSER_AUTOMATION_BACKEND=null
GRACEKELLY_BROWSER_PROFILE_DIR=
GRACEKELLY_BROWSER_BASE_URL=https://www.perplexity.ai

# --- Browser Playwright ---
GRACEKELLY_BROWSER_PLAYWRIGHT_CHANNEL=chrome
GRACEKELLY_BROWSER_PLAYWRIGHT_HEADLESS=false

# --- Browser Circuit Breaker ---
GRACEKELLY_BROWSER_CIRCUIT_BREAKER_ENABLED=true
GRACEKELLY_BROWSER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
GRACEKELLY_BROWSER_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# --- Browser Scripted ---
GRACEKELLY_BROWSER_SCRIPTED_LOGGED_IN=true
GRACEKELLY_BROWSER_SCRIPTED_MODEL_LABEL=
GRACEKELLY_BROWSER_SCRIPTED_OUTPUT_TEXT=scripted browser result

# --- Storage/Postgres ---
GRACEKELLY_STORAGE_BACKEND=memory
GRACEKELLY_POSTGRES_DSN=
GRACEKELLY_POSTGRES_CONNECT_TIMEOUT_SECONDS=5
GRACEKELLY_POSTGRES_POOL_ENABLED=false
GRACEKELLY_POSTGRES_POOL_MIN_SIZE=1
GRACEKELLY_POSTGRES_POOL_MAX_SIZE=5

# --- Execution ---
GRACEKELLY_EXECUTION_PROFILE=dry-run

# --- Orchestration timeout ---
# Request timeout for POST /api/v1/orchestrate (seconds, 0=disabled).
# When exceeded the endpoint returns HTTP 504. Tune based on your slowest model.
# GRACEKELLY_ORCHESTRATE_TIMEOUT_SECONDS=0

# --- Health ---
# Set true to expose internal component details in GET /health (default false).
# Keep false in production — the detailed view includes storage and browser state.
# GRACEKELLY_HEALTH_EXPOSE_DETAILS=false

# --- Mistral API (optional fallback - also provides embeddings for consensus v2) ---
GRACEKELLY_MISTRAL_API_KEY=
GRACEKELLY_MISTRAL_BASE_URL=https://api.mistral.ai/v1
GRACEKELLY_MISTRAL_TIMEOUT_SECONDS=30
GRACEKELLY_MISTRAL_MAX_RETRIES=0
GRACEKELLY_MISTRAL_RETRY_BACKOFF_SECONDS=1.0

# --- OpenAI API (optional fallback) ---
GRACEKELLY_OPENAI_API_KEY=
GRACEKELLY_OPENAI_BASE_URL=https://api.openai.com/v1
GRACEKELLY_OPENAI_TIMEOUT_SECONDS=60
GRACEKELLY_OPENAI_MAX_RETRIES=0
GRACEKELLY_OPENAI_RETRY_BACKOFF_SECONDS=1.0

# --- Anthropic API (optional fallback) ---
GRACEKELLY_ANTHROPIC_API_KEY=
GRACEKELLY_ANTHROPIC_BASE_URL=https://api.anthropic.com
GRACEKELLY_ANTHROPIC_TIMEOUT_SECONDS=120
GRACEKELLY_ANTHROPIC_MAX_RETRIES=0
GRACEKELLY_ANTHROPIC_RETRY_BACKOFF_SECONDS=1.0
